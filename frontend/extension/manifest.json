{
  "manifest_version": 3,
  "name": "TaskFlow Extension",
  "version": "1.0",
  "description": "Quickly add tasks to TaskFlow from anywhere.",
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "http://localhost:5000/*",
    "http://localhost:5173/*",
    "http://localhost:3000/*",
    "http://127.0.0.1:5173/*",
    "http://127.0.0.1:3000/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "http://localhost:5173/*",
        "http://localhost:3000/*",
        "http://127.0.0.1:5173/*",
        "http://127.0.0.1:3000/*"
      ],
      "js": ["content.js"]
    }
  ]
}
